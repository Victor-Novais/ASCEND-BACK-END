generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


enum Role {
  ADMIN
  AVALIADOR
  CLIENTE
  COLLABORATOR
}

enum CompanySize {
  MICRO
  PEQUENA
  MEDIA
  GRANDE
}

enum QuestionCategory {
  GOVERNANCA
  SEGURANCA
  PROCESSOS
  INFRAESTRUTURA
  CULTURA
}

enum ResponseType {
  YES_NO
  SCALE
}

enum AssessmentStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SUBMITTED
}

enum MaturityLevel {
  ARTESANAL
  EFICIENTE
  EFICAZ
  ESTRATEGICO
}



model User {
  id        String   @id @db.Uuid
  name      String?
  email     String   @unique
  passwordHash String
  role      Role
  createdAt DateTime @default(now())

  companiesCreated Company[] @relation("CompanyCreator")
  assessments      Assessment[] @relation("Assessor")

  assignments UserCompanyAssignment[]
  questionsCreated Question[] @relation("QuestionCreator")
  questionVersionsChanged QuestionVersion[]
  assessmentResponses     AssessmentResponse[]
  assessmentAssignments   AssessmentAssignment[]
}



model Company {
  id                 Int          @id @default(autoincrement())
  companyCode        String       @unique
  name               String
  segment            String
  size               CompanySize?
  responsible        String
  responsibleEmail   String
  responsiblePhone   String?
  cnpj               String?
  address            String?
  createdAt          DateTime     @default(now())

  createdById String?   @db.Uuid
  createdBy   User? @relation("CompanyCreator", fields: [createdById], references: [id])

  assessments Assessment[]
  assignments UserCompanyAssignment[]
  history     AssessmentHistory[]
}



model UserCompanyAssignment {
  id        Int      @id @default(autoincrement())
  userId    String   @db.Uuid
  companyId Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@unique([userId, companyId])
}



model Question {
  id               Int               @id @default(autoincrement())
  version          Int
  text             String
  category         QuestionCategory
  weight           Decimal           @db.Decimal(3, 2)
  responseType     ResponseType
  evidenceRequired Boolean
  hint             String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  createdById String @db.Uuid
  createdBy   User @relation("QuestionCreator", fields: [createdById], references: [id])

  responses AssessmentResponse[]
  versions  QuestionVersion[]
}

model QuestionnaireTemplate {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  questions   QuestionTemplate[]
  assessments Assessment[]
}

model QuestionTemplate {
  id                      Int              @id @default(autoincrement())
  questionnaireTemplateId Int
  text                    String
  category                QuestionCategory
  weight                  Decimal          @db.Decimal(3, 2)
  responseType            ResponseType
  evidenceRequired        Boolean          @default(false)
  hint                    String?
  sortOrder               Int              @default(0)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  questionnaireTemplate QuestionnaireTemplate @relation(fields: [questionnaireTemplateId], references: [id], onDelete: Cascade)
  options               QuestionTemplateOption[]

  @@index([questionnaireTemplateId])
}

model QuestionTemplateOption {
  id                 Int     @id @default(autoincrement())
  questionTemplateId Int
  label              String
  /// Score on a 0–5 scale; normalized to 0–100 in the scoring engine.
  scoreValue         Decimal @db.Decimal(4, 2)
  sortOrder          Int     @default(0)

  questionTemplate QuestionTemplate @relation(fields: [questionTemplateId], references: [id], onDelete: Cascade)

  @@index([questionTemplateId])
}

enum AssessmentAssignmentStatus {
  PENDING
  SUBMITTED
}

model AssessmentAssignment {
  id           Int                        @id @default(autoincrement())
  assessmentId Int
  userId       String                     @db.Uuid
  status       AssessmentAssignmentStatus @default(PENDING)
  submittedAt  DateTime?
  createdAt    DateTime                   @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, userId])
  @@index([userId])
}



model QuestionVersion {
  id         Int      @id @default(autoincrement())
  questionId Int
  version    Int
  text       String
  weight     Decimal  @db.Decimal(3, 2)
  changedAt  DateTime @default(now())

  changedById String @db.Uuid
  changedBy   User @relation(fields: [changedById], references: [id])

  question Question @relation(fields: [questionId], references: [id])
}


model Assessment {
  id            Int              @id @default(autoincrement())
  companyId     Int
  assessorId    String           @db.Uuid
  /// When set, questions come from this global template; scoring aggregates collaborator submissions.
  questionnaireTemplateId Int?
  status        AssessmentStatus @default(NOT_STARTED)
  startedAt     DateTime?
  completedAt   DateTime?
  totalScore    Decimal?         @db.Decimal(5, 2)
  maturityLevel MaturityLevel?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  company                 Company                 @relation(fields: [companyId], references: [id])
  assessor                User                    @relation("Assessor", fields: [assessorId], references: [id])
  questionnaireTemplate   QuestionnaireTemplate?  @relation(fields: [questionnaireTemplateId], references: [id])
  assignments             AssessmentAssignment[]
  questions               AssessmentQuestion[]

  responses AssessmentResponse[]
  report    Report?
  history   AssessmentHistory[]
}

model AssessmentQuestion {
  id           Int      @id @default(autoincrement())
  assessmentId Int
  text         String
  category     QuestionCategory?
  order        Int?
  responseType ResponseType
  weight       Decimal  @db.Decimal(3, 2)
  createdAt    DateTime @default(now())

  assessment Assessment               @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  options    AssessmentQuestionOption[]
  responses  AssessmentResponse[]

  @@index([assessmentId])
}

model AssessmentQuestionOption {
  id                   Int    @id @default(autoincrement())
  assessmentQuestionId Int
  text                 String
  weight               Int
  order                Int?

  question AssessmentQuestion @relation(fields: [assessmentQuestionId], references: [id], onDelete: Cascade)

  @@index([assessmentQuestionId])
}


model AssessmentResponse {
  id                 Int       @id @default(autoincrement())
  assessmentId       Int
  /// Legacy single-evaluator assessments (no template).
  questionId         Int?
  /// Cloned assessment question id (template-based).
  assessmentQuestionId Int?
  /// Selected cloned option id.
  selectedOptionId   Int?
  userId             String?   @db.Uuid
  questionVersion    Int
  responseValue      String
  score              Decimal   @db.Decimal(5, 2)
  evidence           String?
  evidenceFileUrl    String?
  observation        String?
  answeredAt         DateTime?
  createdAt          DateTime  @default(now())

  assessment       Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question         Question?         @relation(fields: [questionId], references: [id])
  assessmentQuestion AssessmentQuestion? @relation(fields: [assessmentQuestionId], references: [id])
  user             User?             @relation(fields: [userId], references: [id])

  evidenceFiles EvidenceFile[]

  @@index([assessmentId, userId])
  @@index([assessmentId, assessmentQuestionId])
}



model EvidenceFile {
  id         Int      @id @default(autoincrement())
  responseId Int
  fileName   String
  fileUrl    String
  fileSize   Int
  mimeType   String
  uploadedAt DateTime @default(now())

  response AssessmentResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
}



model Report {
  id               Int      @id @default(autoincrement())
  assessmentId     Int      @unique
  totalScore       Decimal  @db.Decimal(5, 2)
  maturityLevel    MaturityLevel
  categoryScores   Json
  strengths        Json
  weaknesses       Json
  recommendations  Json
  generatedAt      DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
}


model AssessmentHistory {
  id             Int      @id @default(autoincrement())
  companyId      Int
  assessmentId   Int
  totalScore     Decimal  @db.Decimal(5, 2)
  maturityLevel  MaturityLevel
  categoryScores Json
  assessedAt     DateTime @default(now())

  company    Company    @relation(fields: [companyId], references: [id])
  assessment Assessment @relation(fields: [assessmentId], references: [id])
}